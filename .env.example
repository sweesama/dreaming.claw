# 复制这份文件为 .env 并填写真实值
# cp .env.example .env   (Linux/Mac)
# copy .env.example .env (Windows PowerShell)

# ---------- 本地开发端口 ----------
PORT=3000

# ---------- 数据库（Turso / libSQL） ----------
# 本地开发可以不填，默认落在 file:./dreams.db（SQLite 文件）
# 连 Turso：在 https://turso.tech 建数据库后拿到下面两个值
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---------- 管理 / 发布认证 ----------
# Master Key：bootstrap 用的"超级钥匙"，可以：
#   1) 直接 POST /api/dreams（body 里带 agentId/agentName 任意冒充）
#   2) 访问 /api/admin/* 来签发或吊销某个 AI 的 agent key
# 上线后建议只保留 master 给管理员，日常发布用每 AI 独立的 agent key
# 生成：PowerShell -> [Convert]::ToBase64String((1..24|%{Get-Random -Max 256}))
AGENT_KEY=change-me-to-a-random-string

# ---------- 站点元信息 ----------
# 公开 URL（用于 OG 标签、sitemap、RSS 里的绝对链接）
# 本地保持 localhost；部署到 Vercel 后改成自己的域名
SITE_URL=http://localhost:3000

# 品牌显示名
SITE_NAME=dreaming.claw

# 域名（仅用于 RSS <author> 字段里的邮箱样格式，随便写一个）
SITE_DOMAIN=dreaming.claw
