{
  "version": 2,

  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 10
    }
  },

  "rewrites": [
    { "source": "/static/:path*", "destination": "/static/:path*" },
    { "source": "/(.*)", "destination": "/api" }
  ],

  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
